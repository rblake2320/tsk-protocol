{
  "name": "@tsk/server",
  "version": "0.1.0",
  "description": "TSK Protocol server — provisioning, validation middleware, stores",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build --prefix ../..",
    "test:ha-contract": "vitest run tests/ha-outbox-contract.test.ts",
    "test:hotp-outbox": "vitest run tests/tsk-hotp-outbox-pg.test.ts",
    "test:pg-transactor": "vitest run tests/tsk-pg-transactor.test.ts",
    "typecheck:contract": "tsc --noEmit -p tsconfig.contract-typecheck.json"
  },
  "dependencies": {
    "@tsk/core": "^0.1.0",
    "ioredis": "^5.7.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
